      <data key="d3">Particula XVIII.:Exeundi prohibitio | Particula XXII.: Augustalis oratio pro vindicta | Quando capta est per vim Rocca de Archis</data>
      <data key="d4">Liber ad Honorem Augusti</data>
      <data key="d5">Archis enim 'princeps' nomen et esse gerit. | Est michi Corradus Capue, Dipoldus in Archi: | Quodam forte die veniens Dipuldus ab Archi,</data>
      <data key="d6">[{"text": "Archis enim 'princeps' nomen et esse gerit.", "section": "Quando capta est per vim Rocca de Archis", "lineIndex": 345, "documentId": "ebulo"}, {"text": "Est michi Corradus Capue, Dipoldus in Archi:", "section": "Particula XVIII.:Exeundi prohibitio", "lineIndex": 621, "documentId": "ebulo"}, {"text": "Quodam forte die veniens Dipuldus ab Archi,", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1229, "documentId": "ebulo"}]</data>
    </node>
    <node id="50f6c35e-74e4-59cb-bd2b-6a05d90bc82a">
      <data key="d0">Philippus</data>
      <data key="d1">person</data>
      <data key="d2">4</data>
      <data key="d3">LIBER DE REGNO SICILIE | Particula XI.: Regni legatio | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Scripsit cum triplici prole Philippus idem. | Cum quo, cui nomen Guarna, Philippus erat. | Quam, nec adhuc visa fronte, Philippus amat. | Sequenti die rex Henricum Aristippum, archidiaconum Cataniensem, mansuetissimi virum ingenii et tam latinis quam grecis litteris eruditum, familiarem sibi delegit ut vicem et of...</data>
      <data key="d6">[{"text": "Scripsit cum triplici prole Philippus idem.", "section": "Particula XI.: Regni legatio", "lineIndex": 303, "documentId": "ebulo"}, {"text": "Cum quo, cui nomen Guarna, Philippus erat.", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1181, "documentId": "ebulo"}, {"text": "Quam, nec adhuc visa fronte, Philippus amat.", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1324, "documentId": "ebulo"}, {"text": "Sequenti die rex Henricum Aristippum, archidiaconum Cataniensem, mansuetissimi virum ingenii et tam latinis quam grecis litteris eruditum, familiarem sibi delegit ut vicem et of...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 92, "documentId": "falcandus"}]</data>
    </node>
    <node id="4a5371b4-cf6c-58dd-8e38-02657efa80fb">
      <data key="d0">Octavian</data>
      <data key="d1">person</data>
      <data key="d2">2</data>
