      <data key="d7">rule</data>
      <data key="d8">3.2</data>
      <data key="d9">Scribit itaque cancellario uti Robertum comitem Lorotelli tanquam ad audiendum regis imperium Capuam evocet idque modis omnibus agat ut eumdem captum, sub fida custodia Panormum...</data>
      <data key="d10">LIBER DE REGNO SICILIE</data>
