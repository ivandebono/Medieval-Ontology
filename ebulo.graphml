      <data key="d7">marriage</data>
      <data key="d8">5.0</data>
      <data key="d9">Per idem tempus Richardus de Sagio Panormum veniens, uxorem suam, sororem Bartholomei Parisini, secum adduxerat, ut ea dimissa, neptem archiepiscopi Capuani, nobilissimam meretr...</data>
