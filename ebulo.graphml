    <node id="db45fd2d-46f8-5707-8610-a1e6b984efb8">
      <data key="d0">Lucius III</data>
      <data key="d1">person</data>
      <data key="d2">4</data>
      <data key="d3">Incipit prima primi regis Siciliae particula | LIBER DE REGNO SICILIE</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Lucius in nuptu pronuba causa fuit. | Lucius hos iungit, quos Celestinus inungit: | Sequenti die rex Henricum Aristippum, archidiaconum Cataniensem, mansuetissimi virum ingenii et tam latinis quam grecis litteris eruditum, familiarem sibi delegit ut vicem et of... | Pepercit autem rex consanguineo suo Rogerio comiti Avellini quod in aliis crimen atrocissimum iudicabat, in eo putans ob etatis lubricum errorem debere non facinus appellari, si...</data>
      <data key="d6">[{"text": "Lucius in nuptu pronuba causa fuit.", "section": "Incipit prima primi regis Siciliae particula", "lineIndex": 23, "documentId": "ebulo"}, {"text": "Lucius hos iungit, quos Celestinus inungit:", "section": "Incipit prima primi regis Siciliae particula", "lineIndex": 24, "documentId": "ebulo"}, {"text": "Sequenti die rex Henricum Aristippum, archidiaconum Cataniensem, mansuetissimi virum ingenii et tam latinis quam grecis litteris eruditum, familiarem sibi delegit ut vicem et of...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 92, "documentId": "falcandus"}, {"text": "Pepercit autem rex consanguineo suo Rogerio comiti Avellini quod in aliis crimen atrocissimum iudicabat, in eo putans ob etatis lubricum errorem debere non facinus appellari, si...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 106, "documentId": "falcandus"}]</data>
    </node>
