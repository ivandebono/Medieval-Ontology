      <data key="d4">Liber ad Honorem Augusti</data>
      <data key="d5">Offertur digitis, Octaviane, tuis. | Et Iovis et magni tempus novat Octaviani.</data>
      <data key="d6">[{"text": "Offertur digitis, Octaviane, tuis.", "section": "Particula IX.: Abortivi fallax iniquitas proscribit ascriptos", "lineIndex": 291, "documentId": "ebulo"}, {"text": "Et Iovis et magni tempus novat Octaviani.", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1343, "documentId": "ebulo"}]</data>
