    <node id="512505ef-56e2-567f-a37b-8f3d6a3f6b24">
      <data key="d0">Rome</data>
      <data key="d1">place</data>
      <data key="d2">21</data>
      <data key="d3">Incipit liber tercius ad honorem et gloriam magni imperatoris | Incipit prima primi regis Siciliae particula | LIBER DE REGNO SICILIE | Particula IX.: Abortivi fallax iniquitas proscribit ascriptos | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Per quam Romani cresceret orbis honor. | Exultat pompis inclita Roma novis. | Ex oriente deus, Romanum protege solem, | Ei michi, quid prosunt, que tibi, Roma, dedi ? | Ei michi, nec tutum est Romane credere puppi, | Vive, Iovis proles, Romani nominis heres,</data>
      <data key="d6">[{"text": "Per quam Romani cresceret orbis honor.", "section": "Incipit prima primi regis Siciliae particula", "lineIndex": 15, "documentId": "ebulo"}, {"text": "Exultat pompis inclita Roma novis.", "section": "Particula IX.: Abortivi fallax iniquitas proscribit ascriptos", "lineIndex": 265, "documentId": "ebulo"}, {"text": "Ex oriente deus, Romanum protege solem,", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 669, "documentId": "ebulo"}, {"text": "Ei michi, quid prosunt, que tibi, Roma, dedi ?", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1312, "documentId": "ebulo"}, {"text": "Ei michi, nec tutum est Romane credere puppi,", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1321, "documentId": "ebulo"}, {"text": "Vive, Iovis proles, Romani nominis heres,", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1444, "documentId": "ebulo"}]</data>
    </node>
