    <node id="ff648d37-240a-5651-ae0b-0bf06171f665">
      <data key="d0">Constance of Sicily</data>
      <data key="d1">person</data>
      <data key="d2">7</data>
      <data key="d3">Incipit prima primi regis Siciliae particula | LIBER DE REGNO SICILIE | Particula V.: Suasio vicecancellarii dissuadentis ad presulem Panormi | Particula XVI.: Augustalis ingressus in urbem | Particula XVIII.:Exeundi prohibitio | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Traditur Augusto coniux Constantia magno; | Pacis iter, rationis amor, constantia veri, | Elige, quis regnet! Quis erit?" - "Constancia regnet! | Ingreditur patrias tandem Constancia sedes, | Exclamant: "Quid agis, Constancia ? Stamina pensas ? | A rate descendens, ylari Constantia vultu</data>
      <data key="d6">[{"text": "Traditur Augusto coniux Constantia magno;", "section": "Incipit prima primi regis Siciliae particula", "lineIndex": 22, "documentId": "ebulo"}, {"text": "Pacis iter, rationis amor, constantia veri,", "section": "Particula V.: Suasio vicecancellarii dissuadentis ad presulem Panormi", "lineIndex": 116, "documentId": "ebulo"}, {"text": "Elige, quis regnet! Quis erit?\" - \"Constancia regnet!", "section": "Particula V.: Suasio vicecancellarii dissuadentis ad presulem Panormi", "lineIndex": 120, "documentId": "ebulo"}, {"text": "Ingreditur patrias tandem Constancia sedes,", "section": "Particula XVI.: Augustalis ingressus in urbem", "lineIndex": 440, "documentId": "ebulo"}, {"text": "Exclamant: \"Quid agis, Constancia ? Stamina pensas ?", "section": "Particula XVIII.:Exeundi prohibitio", "lineIndex": 570, "documentId": "ebulo"}, {"text": "A rate descendens, ylari Constantia vultu", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 739, "documentId": "ebulo"}]</data>
    </node>
    <node id="72e46d1d-504a-5a22-a6cc-580e4fad7c60">
