    <node id="4c9a8821-3d41-515a-be1e-dc413c366744">
      <data key="d0">Frederick I Barbarossa</data>
      <data key="d1">person</data>
      <data key="d2">8</data>
      <data key="d3">Incipit liber tercius ad honorem et gloriam magni imperatoris | Particula XII.:Primus imperatoris ingressus in regna Sicilie | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti</data>
      <data key="d5">Nec minor est Fredericus eo, qui duxit ab illo | Exhinc Rogerius, hinc Fredericus eris, | Sexta Fredericum divo depingit amictu, | Hic Fredericus ovans in milibus undique fretus | Qualiter invito te Fredericus abit. | Hic Frederici ales fulminat ense procer.</data>
      <data key="d6">[{"text": "Nec minor est Fredericus eo, qui duxit ab illo", "section": "Particula XII.:Primus imperatoris ingressus in regna Sicilie", "lineIndex": 318, "documentId": "ebulo"}, {"text": "Exhinc Rogerius, hinc Fredericus eris,", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1411, "documentId": "ebulo"}, {"text": "Sexta Fredericum divo depingit amictu,", "section": "Incipit liber tercius ad honorem et gloriam magni imperatoris", "lineIndex": 1620, "documentId": "ebulo"}, {"text": "Hic Fredericus ovans in milibus undique fretus", "section": "Incipit liber tercius ad honorem et gloriam magni imperatoris", "lineIndex": 1622, "documentId": "ebulo"}, {"text": "Qualiter invito te Fredericus abit.", "section": "Incipit liber tercius ad honorem et gloriam magni imperatoris", "lineIndex": 1629, "documentId": "ebulo"}, {"text": "Hic Frederici ales fulminat ense procer.", "section": "Incipit liber tercius ad honorem et gloriam magni imperatoris", "lineIndex": 1635, "documentId": "ebulo"}]</data>
    </node>
    <node id="6e3d3775-c5aa-5aa5-b364-792be69b0654">
      <data key="d0">Lupini brothers</data>
      <data key="d1">group</data>
      <data key="d2">2</data>
      <data key="d3">LIBER DE REGNO SICILIE | Particula XI.: Regni legatio</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Et gemini fratres magni scripsere Lupini, | Inter has rerum ambiguitates et pericula cancellarius deprehensus, ab Ansaldo castellano statuit sciscitari quid ei potissimum in tanto turbine faciendum decerneret. Cuius consi...</data>
      <data key="d6">[{"text": "Et gemini fratres magni scripsere Lupini,", "section": "Particula XI.: Regni legatio", "lineIndex": 304, "documentId": "ebulo"}, {"text": "Inter has rerum ambiguitates et pericula cancellarius deprehensus, ab Ansaldo castellano statuit sciscitari quid ei potissimum in tanto turbine faciendum decerneret. Cuius consi...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 193, "documentId": "falcandus"}]</data>
    </node>
    <node id="8c2b1c8f-da61-5b21-8a78-5e0a732f4049">
      <data key="d0">Roger of Andria</data>
      <data key="d1">person</data>
      <data key="d2">30</data>
      <data key="d3">LIBER DE REGNO SICILIE | Particula IV.: Adversa et diversa petentium voluntas | Particula IX.: Abortivi fallax iniquitas proscribit ascriptos | Particula V.: Suasio vicecancellarii dissuadentis ad presulem Panormi | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Tancredum petit hic, comitem petit ille Rogerum: | "Ad solium regni comitem gerit Andria dignum! " - | Cum foret ille tuus falso comes, Andria, captus, | Exhinc Rogerius, hinc Fredericus eris, | Primum igitur satis constat quod cum Rogerius comes Sicilie, frater Roberti Guiscardi ducis Apulie, rebus excessisset humanis, Rogerius eius filius totam primum Siciliam ac part... | Eoque ipso spe subnixa, regnandi cupiditas acriores viro stimulos ingerebat. Scribit itaque cancellario uti Robertum comitem Lorotelli tanquam ad audiendum regis imperium Capuam...</data>
      <data key="d6">[{"text": "Tancredum petit hic, comitem petit ille Rogerum:", "section": "Particula IV.: Adversa et diversa petentium voluntas", "lineIndex": 98, "documentId": "ebulo"}, {"text": "\"Ad solium regni comitem gerit Andria dignum! \" -", "section": "Particula V.: Suasio vicecancellarii dissuadentis ad presulem Panormi", "lineIndex": 126, "documentId": "ebulo"}, {"text": "Cum foret ille tuus falso comes, Andria, captus,", "section": "Particula IX.: Abortivi fallax iniquitas proscribit ascriptos", "lineIndex": 248, "documentId": "ebulo"}, {"text": "Exhinc Rogerius, hinc Fredericus eris,", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1411, "documentId": "ebulo"}, {"text": "Primum igitur satis constat quod cum Rogerius comes Sicilie, frater Roberti Guiscardi ducis Apulie, rebus excessisset humanis, Rogerius eius filius totam primum Siciliam ac part...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 58, "documentId": "falcandus"}, {"text": "Eoque ipso spe subnixa, regnandi cupiditas acriores viro stimulos ingerebat. Scribit itaque cancellario uti Robertum comitem Lorotelli tanquam ad audiendum regis imperium Capuam...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 66, "documentId": "falcandus"}]</data>
    </node>
    <node id="d1afba32-69be-5bc6-a0c5-d84ff2867174">
      <data key="d0">Henry VI</data>
      <data key="d1">person</data>
      <data key="d2">107</data>
      <data key="d3">Front Matter | Incipit liber tercius ad honorem et gloriam magni imperatoris | Incipit prima primi regis Siciliae particula | LIBER DE REGNO SICILIE | Particula IX.: Abortivi fallax iniquitas proscribit ascriptos | Particula V.: Suasio vicecancellarii dissuadentis ad presulem Panormi | Particula VII.: Spuriosa unctio regni | Particula XII.:Primus imperatoris ingressus in regna Sicilie | Particula XIII.: Castrorum inclinatur proceritas | Particula XIV.: Urbs Neapolis obsessa resistit | Particula XV.: Comitis percussio et Salerni exaudita petitio | Particula XVI.: Augustalis ingressus in urbem | Particula XVIII.:Exeundi prohibitio | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Petrus de Ebulo: Liber ad honorem Augusti sive de rebus Siculis | Traditur Augusto coniux Constantia magno; | Sic notat Henricus sextus utrumque patrem. | A quibus Henricus munera bina capit. | "Disce prius mores Augusti, disce furorem! | Pro Iove semivirum, magno pro Cesare nanum</data>
      <data key="d6">[{"text": "Petrus de Ebulo: Liber ad honorem Augusti sive de rebus Siculis", "section": "Front Matter", "lineIndex": 0, "documentId": "ebulo"}, {"text": "Traditur Augusto coniux Constantia magno;", "section": "Incipit prima primi regis Siciliae particula", "lineIndex": 22, "documentId": "ebulo"}, {"text": "Sic notat Henricus sextus utrumque patrem.", "section": "Incipit prima primi regis Siciliae particula", "lineIndex": 27, "documentId": "ebulo"}, {"text": "A quibus Henricus munera bina capit.", "section": "Incipit prima primi regis Siciliae particula", "lineIndex": 31, "documentId": "ebulo"}, {"text": "\"Disce prius mores Augusti, disce furorem!", "section": "Particula V.: Suasio vicecancellarii dissuadentis ad presulem Panormi", "lineIndex": 122, "documentId": "ebulo"}, {"text": "Pro Iove semivirum, magno pro Cesare nanum", "section": "Particula VII.: Spuriosa unctio regni", "lineIndex": 200, "documentId": "ebulo"}]</data>
    </node>
    <node id="c46bc1d7-ae5b-5699-a5de-50a90cf0f693">
