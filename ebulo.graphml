    <node id="e6a714ea-1866-510c-a7af-f75692bf3c5d">
      <data key="d0">Bartholomew</data>
      <data key="d1">person</data>
      <data key="d2">5</data>
      <data key="d3">LIBER DE REGNO SICILIE | Particula XI.: Regni legatio</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Scripserat et presul Bartholomeus idem. | Interea iam incipiente turbari Sicilia, Bartholomeus de Garsiliato cum quibusdam aliis Buteriam occupat, locum utique munitissimum et adversus quoslibet obsidentium impetus prer... | Sic hostium machinis dissolutis et consiliis redactis in nichilum, electus in curie familiaritate permansit. Per idem tempus Richardus de Sagio Panormum veniens, uxorem suam, so... | Videntes interea Messanenses de totius regni partibus [ad curia]m multam virorum ac mulierum turbam confluere, neque suo quempiam iure fraudari, sed in omnibus iudiciis district... | Henricus itaque comes audiens ex insperato palam esse cuncta que gesserat, tanti se criminis obiectione pulsari, neque dari sibi copiam ut quamlibet dilationis interim causam op...</data>
      <data key="d6">[{"text": "Scripserat et presul Bartholomeus idem.", "section": "Particula XI.: Regni legatio", "lineIndex": 307, "documentId": "ebulo"}, {"text": "Interea iam incipiente turbari Sicilia, Bartholomeus de Garsiliato cum quibusdam aliis Buteriam occupat, locum utique munitissimum et adversus quoslibet obsidentium impetus prer...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 74, "documentId": "falcandus"}, {"text": "Sic hostium machinis dissolutis et consiliis redactis in nichilum, electus in curie familiaritate permansit. Per idem tempus Richardus de Sagio Panormum veniens, uxorem suam, so...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 131, "documentId": "falcandus"}, {"text": "Videntes interea Messanenses de totius regni partibus [ad curia]m multam virorum ac mulierum turbam confluere, neque suo quempiam iure fraudari, sed in omnibus iudiciis district...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 184, "documentId": "falcandus"}, {"text": "Henricus itaque comes audiens ex insperato palam esse cuncta que gesserat, tanti se criminis obiectione pulsari, neque dari sibi copiam ut quamlibet dilationis interim causam op...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 185, "documentId": "falcandus"}]</data>
    </node>
    <node id="0871545f-81eb-5e21-b0fc-e5ea1f44dfa1">
      <data key="d0">Walter of Palermo</data>
      <data key="d1">person</data>
      <data key="d2">28</data>
      <data key="d3">LIBER DE REGNO SICILIE | Particula IV.: Adversa et diversa petentium voluntas | Particula XI.: Regni legatio | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Hoc negat antistes, qui gualterizatur ubique, | Scripsit et antistes, dominorum gemma Panormi, | Legati quem preveniunt ex urbe Panormi, | Inter alias ergo nature dotes, quibus ingentis spiritus virum ipsa ditaverat, promtissimus erat ingenio nec nunquam adeo sibi diffidens ut de qualibet re consultus vel modicam r... | Dum hec inter eos Panormi versantur consilia, rex Farum transire disposuit, ac primo Messanam, dehinc, paucis post diebus, Salernum proficiscitur. Cumque ex diversis Apulie et T... | Hec ubi Panormi cognita sunt, inopinata res admirati paulisper animum conturbavit, non tamen usque adeo ut vultum quoque sufficeret immutare. Nam in maximis quoque periculis ex...</data>
      <data key="d6">[{"text": "Hoc negat antistes, qui gualterizatur ubique,", "section": "Particula IV.: Adversa et diversa petentium voluntas", "lineIndex": 104, "documentId": "ebulo"}, {"text": "Scripsit et antistes, dominorum gemma Panormi,", "section": "Particula XI.: Regni legatio", "lineIndex": 306, "documentId": "ebulo"}, {"text": "Legati quem preveniunt ex urbe Panormi,", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1263, "documentId": "ebulo"}, {"text": "Inter alias ergo nature dotes, quibus ingentis spiritus virum ipsa ditaverat, promtissimus erat ingenio nec nunquam adeo sibi diffidens ut de qualibet re consultus vel modicam r...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 59, "documentId": "falcandus"}, {"text": "Dum hec inter eos Panormi versantur consilia, rex Farum transire disposuit, ac primo Messanam, dehinc, paucis post diebus, Salernum proficiscitur. Cumque ex diversis Apulie et T...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 64, "documentId": "falcandus"}, {"text": "Hec ubi Panormi cognita sunt, inopinata res admirati paulisper animum conturbavit, non tamen usque adeo ut vultum quoque sufficeret immutare. Nam in maximis quoque periculis ex...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 70, "documentId": "falcandus"}]</data>
    </node>
    <node id="52d9448d-1d42-599c-a4e8-cd5417ad7b26">
      <data key="d0">Capua</data>
      <data key="d1">place</data>
      <data key="d2">12</data>
      <data key="d3">LIBER DE REGNO SICILIE | Particula XI.: Regni legatio | Particula XV.: Comitis percussio et Salerni exaudita petitio | Particula XVIII.:Exeundi prohibitio | Quando Capuanus antistes gaudens Augustum recepit</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Scripsit et antistes hoc Capuanus idem. | I, Capuane pater, nec te consulta morentur; | Protinus almipater Capuane sedulus urbis, | Est michi Corradus Capue, Dipoldus in Archi: | Inter alias ergo nature dotes, quibus ingentis spiritus virum ipsa ditaverat, promtissimus erat ingenio nec nunquam adeo sibi diffidens ut de qualibet re consultus vel modicam r... | Eoque ipso spe subnixa, regnandi cupiditas acriores viro stimulos ingerebat. Scribit itaque cancellario uti Robertum comitem Lorotelli tanquam ad audiendum regis imperium Capuam...</data>
      <data key="d6">[{"text": "Scripsit et antistes hoc Capuanus idem.", "section": "Particula XI.: Regni legatio", "lineIndex": 305, "documentId": "ebulo"}, {"text": "I, Capuane pater, nec te consulta morentur;", "section": "Quando Capuanus antistes gaudens Augustum recepit", "lineIndex": 348, "documentId": "ebulo"}, {"text": "Protinus almipater Capuane sedulus urbis,", "section": "Particula XV.: Comitis percussio et Salerni exaudita petitio", "lineIndex": 414, "documentId": "ebulo"}, {"text": "Est michi Corradus Capue, Dipoldus in Archi:", "section": "Particula XVIII.:Exeundi prohibitio", "lineIndex": 621, "documentId": "ebulo"}, {"text": "Inter alias ergo nature dotes, quibus ingentis spiritus virum ipsa ditaverat, promtissimus erat ingenio nec nunquam adeo sibi diffidens ut de qualibet re consultus vel modicam r...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 59, "documentId": "falcandus"}, {"text": "Eoque ipso spe subnixa, regnandi cupiditas acriores viro stimulos ingerebat. Scribit itaque cancellario uti Robertum comitem Lorotelli tanquam ad audiendum regis imperium Capuam...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 66, "documentId": "falcandus"}]</data>
    </node>
