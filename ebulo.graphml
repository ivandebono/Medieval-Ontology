      <data key="d7">support</data>
      <data key="d8">3.4</data>
      <data key="d9">Scripsit et antistes, dominorum gemma Panormi,</data>
      <data key="d10">Particula XI.: Regni legatio</data>
      <data key="d11">Liber ad Honorem Augusti</data>
