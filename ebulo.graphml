    <node id="75becb82-7042-5dec-8dd9-29fed85e42bf">
      <data key="d0">William II of Sicily</data>
      <data key="d1">person</data>
      <data key="d2">2</data>
      <data key="d3">LIBER DE REGNO SICILIE</data>
      <data key="d4">Liber de Regno Sicilie</data>
      <data key="d5">Primum igitur satis constat quod cum Rogerius comes Sicilie, frater Roberti Guiscardi ducis Apulie, rebus excessisset humanis, Rogerius eius filius totam primum Siciliam ac part... | Interea comes Gaufredus, cui Fari transitus interdictus fuerat, suadente Maione, privatus oculis carceri datur. Comes Symon, qui Policastri remanserat, ob idem accersitur ad cur...</data>
      <data key="d6">[{"text": "Primum igitur satis constat quod cum Rogerius comes Sicilie, frater Roberti Guiscardi ducis Apulie, rebus excessisset humanis, Rogerius eius filius totam primum Siciliam ac part...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 58, "documentId": "falcandus"}, {"text": "Interea comes Gaufredus, cui Fari transitus interdictus fuerat, suadente Maione, privatus oculis carceri datur. Comes Symon, qui Policastri remanserat, ob idem accersitur ad cur...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 80, "documentId": "falcandus"}]</data>
    </node>
    <node id="878fcb06-2bff-5562-903b-8a74d683179a">
      <data key="d0">Count Molisius</data>
      <data key="d1">person</data>
      <data key="d2">1</data>
      <data key="d3">Particula XI.: Regni legatio</data>
      <data key="d4">Liber ad Honorem Augusti</data>
      <data key="d5">Scripsit Molisius, inclitus ille comes.</data>
      <data key="d6">[{"text": "Scripsit Molisius, inclitus ille comes.", "section": "Particula XI.: Regni legatio", "lineIndex": 301, "documentId": "ebulo"}]</data>
    </node>
    <node id="3874b3a4-2587-551a-9e08-abbdd739c567">
      <data key="d0">Apulia</data>
      <data key="d1">place</data>
      <data key="d2">34</data>
      <data key="d3">LIBER DE REGNO SICILIE | Particula IX.: Abortivi fallax iniquitas proscribit ascriptos | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Mandat, in Apuliam quisque quod ire paret. | Letus in Apuliam properat primoque Salernum | Primum igitur satis constat quod cum Rogerius comes Sicilie, frater Roberti Guiscardi ducis Apulie, rebus excessisset humanis, Rogerius eius filius totam primum Siciliam ac part... | Inter alias ergo nature dotes, quibus ingentis spiritus virum ipsa ditaverat, promtissimus erat ingenio nec nunquam adeo sibi diffidens ut de qualibet re consultus vel modicam r... | Dum hec inter eos Panormi versantur consilia, rex Farum transire disposuit, ac primo Messanam, dehinc, paucis post diebus, Salernum proficiscitur. Cumque ex diversis Apulie et T... | His eo modo gestis, ita rex deinde suam omnibus absentavit presentiam ut per multum temporis spatium, excepto Maione admirato et Hugone archiepiscopo, nulli penitus appareret. Q...</data>
      <data key="d6">[{"text": "Mandat, in Apuliam quisque quod ire paret.", "section": "Particula IX.: Abortivi fallax iniquitas proscribit ascriptos", "lineIndex": 295, "documentId": "ebulo"}, {"text": "Letus in Apuliam properat primoque Salernum", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1176, "documentId": "ebulo"}, {"text": "Primum igitur satis constat quod cum Rogerius comes Sicilie, frater Roberti Guiscardi ducis Apulie, rebus excessisset humanis, Rogerius eius filius totam primum Siciliam ac part...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 58, "documentId": "falcandus"}, {"text": "Inter alias ergo nature dotes, quibus ingentis spiritus virum ipsa ditaverat, promtissimus erat ingenio nec nunquam adeo sibi diffidens ut de qualibet re consultus vel modicam r...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 59, "documentId": "falcandus"}, {"text": "Dum hec inter eos Panormi versantur consilia, rex Farum transire disposuit, ac primo Messanam, dehinc, paucis post diebus, Salernum proficiscitur. Cumque ex diversis Apulie et T...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 64, "documentId": "falcandus"}, {"text": "His eo modo gestis, ita rex deinde suam omnibus absentavit presentiam ut per multum temporis spatium, excepto Maione admirato et Hugone archiepiscopo, nulli penitus appareret. Q...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 68, "documentId": "falcandus"}]</data>
    </node>
    <node id="6e27241c-a3a1-59df-9d09-387f3279977e">
      <data key="d0">Sicily</data>
      <data key="d1">place</data>
      <data key="d2">51</data>
      <data key="d3">Front Matter | LIBER DE REGNO SICILIE | Particula II.: Obitus Wilelmi secundi formosi regis Sicilie | Particula VII.: Spuriosa unctio regni | Particula XII.:Primus imperatoris ingressus in regna Sicilie | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Petrus de Ebulo: Liber ad honorem Augusti sive de rebus Siculis | Anglica Sicilidem luna flet orba diem. | Tandem Siciliam gemina cum prole petentis | Que pater a Siculis regibus ipse tulit. | Interea Siculis solo terrore subactis, | Apulus aut Siculus debeat, orbis habet.</data>
      <data key="d6">[{"text": "Petrus de Ebulo: Liber ad honorem Augusti sive de rebus Siculis", "section": "Front Matter", "lineIndex": 0, "documentId": "ebulo"}, {"text": "Anglica Sicilidem luna flet orba diem.", "section": "Particula II.: Obitus Wilelmi secundi formosi regis Sicilie", "lineIndex": 55, "documentId": "ebulo"}, {"text": "Tandem Siciliam gemina cum prole petentis", "section": "Particula VII.: Spuriosa unctio regni", "lineIndex": 176, "documentId": "ebulo"}, {"text": "Que pater a Siculis regibus ipse tulit.", "section": "Particula XII.:Primus imperatoris ingressus in regna Sicilie", "lineIndex": 315, "documentId": "ebulo"}, {"text": "Interea Siculis solo terrore subactis,", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1207, "documentId": "ebulo"}, {"text": "Apulus aut Siculus debeat, orbis habet.", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1356, "documentId": "ebulo"}]</data>
    </node>
    <node id="40f786ec-6db3-5a34-b973-b55125314e9f">
      <data key="d0">Andronicus</data>
      <data key="d1">person</data>
      <data key="d2">4</data>
      <data key="d3">Incipit liber tercius ad honorem et gloriam magni imperatoris | Particula VI.: Epistola ad Tancredum</data>
      <data key="d4">Liber ad Honorem Augusti</data>
      <data key="d5">Andronicus si forte suo iuravit Alexi, | "Sit tuus Andronicus, saturatus cede nepotis, | Sit tuus Andronicus, qui crassus cede suorum | Si potes, Andronicum civilibus eripe telis;</data>
      <data key="d6">[{"text": "Andronicus si forte suo iuravit Alexi,", "section": "Particula VI.: Epistola ad Tancredum", "lineIndex": 160, "documentId": "ebulo"}, {"text": "\"Sit tuus Andronicus, saturatus cede nepotis,", "section": "Incipit liber tercius ad honorem et gloriam magni imperatoris", "lineIndex": 1682, "documentId": "ebulo"}, {"text": "Sit tuus Andronicus, qui crassus cede suorum", "section": "Incipit liber tercius ad honorem et gloriam magni imperatoris", "lineIndex": 1684, "documentId": "ebulo"}, {"text": "Si potes, Andronicum civilibus eripe telis;", "section": "Incipit liber tercius ad honorem et gloriam magni imperatoris", "lineIndex": 1694, "documentId": "ebulo"}]</data>
