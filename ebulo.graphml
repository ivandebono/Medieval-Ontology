    <node id="f2406b5f-d55c-5ff9-a125-55863ceed1f0">
      <data key="d0">Matthew of Ajello</data>
      <data key="d1">person</data>
      <data key="d2">37</data>
      <data key="d3">LIBER DE REGNO SICILIE | Particula IV.: Adversa et diversa petentium voluntas | Particula V.: Suasio vicecancellarii dissuadentis ad presulem Panormi | Particula VI.: Epistola ad Tancredum | Particula VII.: Spuriosa unctio regni | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Votaque Mathei curia tota negat. | Venit Scariothis flens, ubi presul erat. | Talibus almi patris Matheus adulterat archam | "Hanc tibi Matheus mitto Tancrede salutem, | Quam male Scariothis redimit tua festa Matheus, | Nec sapit antidotum, seve Mathee, tuum.</data>
      <data key="d6">[{"text": "Votaque Mathei curia tota negat.", "section": "Particula IV.: Adversa et diversa petentium voluntas", "lineIndex": 105, "documentId": "ebulo"}, {"text": "Venit Scariothis flens, ubi presul erat.", "section": "Particula V.: Suasio vicecancellarii dissuadentis ad presulem Panormi", "lineIndex": 113, "documentId": "ebulo"}, {"text": "Talibus almi patris Matheus adulterat archam", "section": "Particula V.: Suasio vicecancellarii dissuadentis ad presulem Panormi", "lineIndex": 140, "documentId": "ebulo"}, {"text": "\"Hanc tibi Matheus mitto Tancrede salutem,", "section": "Particula VI.: Epistola ad Tancredum", "lineIndex": 144, "documentId": "ebulo"}, {"text": "Quam male Scariothis redimit tua festa Matheus,", "section": "Particula VII.: Spuriosa unctio regni", "lineIndex": 198, "documentId": "ebulo"}, {"text": "Nec sapit antidotum, seve Mathee, tuum.", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 686, "documentId": "ebulo"}]</data>
    </node>
    <node id="f4191f2f-3305-5276-97a9-3fbc7bfc75c3">
      <data key="d0">Charlemagne</data>
      <data key="d1">person</data>
      <data key="d2">3</data>
      <data key="d3">Particula XII.:Primus imperatoris ingressus in regna Sicilie | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti</data>
      <data key="d5">In medio Carolus fulminat orbe tuus. | Vicit in hoc Carulos, fortior hasta, suos. | Multiplicat Carolis nomen et omen avis.</data>
      <data key="d6">[{"text": "In medio Carolus fulminat orbe tuus.", "section": "Particula XII.:Primus imperatoris ingressus in regna Sicilie", "lineIndex": 317, "documentId": "ebulo"}, {"text": "Vicit in hoc Carulos, fortior hasta, suos.", "section": "Particula XII.:Primus imperatoris ingressus in regna Sicilie", "lineIndex": 321, "documentId": "ebulo"}, {"text": "Multiplicat Carolis nomen et omen avis.", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1340, "documentId": "ebulo"}]</data>
    </node>
    <node id="6dce7d67-ce32-595a-858c-6b3af1d051a2">
      <data key="d0">Salerno</data>
      <data key="d1">place</data>
      <data key="d2">20</data>
      <data key="d3">LIBER DE REGNO SICILIE | Particula XI.: Regni legatio | Particula XV.: Comitis percussio et Salerni exaudita petitio | Particula XVI.: Augustalis ingressus in urbem | Particula XVIII.:Exeundi prohibitio | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Scripsit cum multis pius archilevita Salerni, | Hic victor fera bella geras; tua nupta Salerni | Hec ubi legatus notat impetrata Salerni, | "Parce tuis oculis, fidissima cura Salerni, | Consilio stimulata malo gens seva Salerni | Paupere lintheolo tecti venere Salernum,</data>
      <data key="d6">[{"text": "Scripsit cum multis pius archilevita Salerni,", "section": "Particula XI.: Regni legatio", "lineIndex": 308, "documentId": "ebulo"}, {"text": "Hic victor fera bella geras; tua nupta Salerni", "section": "Particula XV.: Comitis percussio et Salerni exaudita petitio", "lineIndex": 402, "documentId": "ebulo"}, {"text": "Hec ubi legatus notat impetrata Salerni,", "section": "Particula XV.: Comitis percussio et Salerni exaudita petitio", "lineIndex": 418, "documentId": "ebulo"}, {"text": "\"Parce tuis oculis, fidissima cura Salerni,", "section": "Particula XVI.: Augustalis ingressus in urbem", "lineIndex": 482, "documentId": "ebulo"}, {"text": "Consilio stimulata malo gens seva Salerni", "section": "Particula XVIII.:Exeundi prohibitio", "lineIndex": 564, "documentId": "ebulo"}, {"text": "Paupere lintheolo tecti venere Salernum,", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1004, "documentId": "ebulo"}]</data>
    </node>
    <node id="f883a35a-fc7a-51da-8a35-7fdafb977f4e">
      <data key="d0">Palermo</data>
      <data key="d1">place</data>
      <data key="d2">42</data>
      <data key="d3">LIBER DE REGNO SICILIE | Particula VII.: Spuriosa unctio regni | Particula XI.: Regni legatio | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Altera mellifluens paradisus, dulce Panormum, | Scripsit et antistes, dominorum gemma Panormi, | Est opus, ut venias merito captiva Panormum; | Pauca quidem loquitur: "Veniam, Tancrede, Panormum | Post hec, assissis sociis, Augusta Panormum | Imperat, ut properent; tutum est properare Panormum.</data>
      <data key="d6">[{"text": "Altera mellifluens paradisus, dulce Panormum,", "section": "Particula VII.: Spuriosa unctio regni", "lineIndex": 196, "documentId": "ebulo"}, {"text": "Scripsit et antistes, dominorum gemma Panormi,", "section": "Particula XI.: Regni legatio", "lineIndex": 306, "documentId": "ebulo"}, {"text": "Est opus, ut venias merito captiva Panormum;", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 695, "documentId": "ebulo"}, {"text": "Pauca quidem loquitur: \"Veniam, Tancrede, Panormum", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 704, "documentId": "ebulo"}, {"text": "Post hec, assissis sociis, Augusta Panormum", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 906, "documentId": "ebulo"}, {"text": "Imperat, ut properent; tutum est properare Panormum.", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1215, "documentId": "ebulo"}]</data>
    </node>
    <node id="8cfb7fa7-d836-57bc-a09e-1ff77116c839">
      <data key="d0">Naples</data>
      <data key="d1">place</data>
      <data key="d2">4</data>
      <data key="d3">Particula XIV.: Urbs Neapolis obsessa resistit | Particula XVIII.:Exeundi prohibitio | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti</data>
      <data key="d5">Sic tua, Parthenope, confinia Cesar obumbrat, | Felix Parthenope, que nec te sola recepit! | Ad te, Parthenope, remus et aura vehit. | Nec tu, Parthenope, quod Cesar abinde recessit,</data>
      <data key="d6">[{"text": "Sic tua, Parthenope, confinia Cesar obumbrat,", "section": "Particula XIV.: Urbs Neapolis obsessa resistit", "lineIndex": 358, "documentId": "ebulo"}, {"text": "Felix Parthenope, que nec te sola recepit!", "section": "Particula XVIII.:Exeundi prohibitio", "lineIndex": 576, "documentId": "ebulo"}, {"text": "Ad te, Parthenope, remus et aura vehit.", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 991, "documentId": "ebulo"}, {"text": "Nec tu, Parthenope, quod Cesar abinde recessit,", "section": "Particula XXII.: Augustalis oratio pro vindicta", "lineIndex": 1030, "documentId": "ebulo"}]</data>
