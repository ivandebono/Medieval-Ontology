      <data key="d6">[{"text": "Dux ubi Roggerius, Guiscardi clara propago,", "section": "Incipit prima primi regis Siciliae particula", "lineIndex": 2, "documentId": "ebulo"}, {"text": "Primum igitur satis constat quod cum Rogerius comes Sicilie, frater Roberti Guiscardi ducis Apulie, rebus excessisset humanis, Rogerius eius filius totam primum Siciliam ac part...", "section": "LIBER DE REGNO SICILIE", "lineIndex": 58, "documentId": "falcandus"}]</data>
