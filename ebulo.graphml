    <node id="786ce4d2-ded3-5d83-b313-02da124db58c">
      <data key="d0">Tancred of Sicily</data>
      <data key="d1">person</data>
      <data key="d2">36</data>
      <data key="d3">Incipit liber tercius ad honorem et gloriam magni imperatoris | LIBER DE REGNO SICILIE | Particula IV.: Adversa et diversa petentium voluntas | Particula V.: Suasio vicecancellarii dissuadentis ad presulem Panormi | Particula VI.: Epistola ad Tancredum | Particula VIII.: Casus anathematizati et derisio nascentis | Particula XV.: Comitis percussio et Salerni exaudita petitio | Particula XVIII.:Exeundi prohibitio | Particula XXII.: Augustalis oratio pro vindicta</data>
      <data key="d4">Liber ad Honorem Augusti | Liber de Regno Sicilie</data>
      <data key="d5">Tancredum petit hic, comitem petit ille Rogerum: | Ut sibi Tancredum gens petat, unus agit. | Aptus ad hoc Tancredus erit, de germine iusto, | "Hanc tibi Matheus mitto Tancrede salutem, | In qua Tancredus regia sceptra tulit. | In qua Tancredus preredimitus abit.</data>
      <data key="d6">[{"text": "Tancredum petit hic, comitem petit ille Rogerum:", "section": "Particula IV.: Adversa et diversa petentium voluntas", "lineIndex": 98, "documentId": "ebulo"}, {"text": "Ut sibi Tancredum gens petat, unus agit.", "section": "Particula IV.: Adversa et diversa petentium voluntas", "lineIndex": 103, "documentId": "ebulo"}, {"text": "Aptus ad hoc Tancredus erit, de germine iusto,", "section": "Particula V.: Suasio vicecancellarii dissuadentis ad presulem Panormi", "lineIndex": 132, "documentId": "ebulo"}, {"text": "\"Hanc tibi Matheus mitto Tancrede salutem,", "section": "Particula VI.: Epistola ad Tancredum", "lineIndex": 144, "documentId": "ebulo"}, {"text": "In qua Tancredus regia sceptra tulit.", "section": "Particula VIII.: Casus anathematizati et derisio nascentis", "lineIndex": 205, "documentId": "ebulo"}, {"text": "In qua Tancredus preredimitus abit.", "section": "Particula VIII.: Casus anathematizati et derisio nascentis", "lineIndex": 207, "documentId": "ebulo"}]</data>
    </node>
    <node id="2f4c8594-8730-5669-b505-1e2ed1bcb350">
      <data key="d0">Rocca de Archis</data>
